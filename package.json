		"@capacitor/ios": "^8.2.0",
		"@capacitor/network": "^8.0.1",
		"@capacitor/status-bar": "^8.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@xyflow/svelte": "1.4.0",
		"better-sqlite3": "^12.6.2",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.9",
		"drizzle-orm": "^0.45.1",
		"lucide-svelte": "^0.577.0",
