<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext (HTTP) traffic for local/LAN gateway connections -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Explicitly allow cleartext to common local/LAN addresses.
         Android <domain> does NOT support CIDR notation — use literal IPs only.
         These match the candidates in scanLanForGateway() in src/lib/tauri.ts -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">192.168.0.1</domain>
        <domain includeSubdomains="false">192.168.1.100</domain>
        <domain includeSubdomains="false">192.168.0.100</domain>
        <domain includeSubdomains="false">192.168.1.2</domain>
        <domain includeSubdomains="false">192.168.0.2</domain>
        <domain includeSubdomains="false">10.0.0.1</domain>
        <domain includeSubdomains="false">10.0.0.2</domain>
        <domain includeSubdomains="false">10.0.1.1</domain>
        <domain includeSubdomains="false">172.16.0.1</domain>
        <domain includeSubdomains="false">172.16.0.2</domain>
        <domain includeSubdomains="false">172.30.80.1</domain>
        <domain includeSubdomains="false">172.17.0.1</domain>
        <domain includeSubdomains="false">172.18.0.1</domain>
    </domain-config>
</network-security-config>
